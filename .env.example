# PostgreSQL Configuration (pour Docker Compose)
POSTGRES_DB=comptabilite_db
POSTGRES_USER=comptabilite_user
POSTGRES_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION_MotDePasseSecurise123
POSTGRES_PORT=5432

# Backend Configuration
SECRET_KEY=CHANGEZ_MOI_GenerezUneCleSuperSecreteAleatoire64Caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (séparer par des virgules)
# Développement local
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (remplacer par votre IP/domaine)
# CORS_ORIGINS=http://VOTRE_IP:3000,http://VOTRE_DOMAINE.com

# Environment
ENVIRONMENT=production
DEBUG=False
ENABLE_AUTH=True
ENABLE_RATE_LIMITING=True

# Note: Pour générer une SECRET_KEY sécurisée, exécutez:
# python -c "import secrets; print(secrets.token_urlsafe(64))"

