# PostgreSQL Configuration
POSTGRES_DB=comptabilite_db
POSTGRES_USER=comptabilite_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Backend Configuration
DATABASE_URL=postgresql://comptabilite_user:change_me_in_production@localhost:5432/comptabilite_db
SECRET_KEY=change_me_to_a_secure_random_secret_key_min_32_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Comptabilité

# Environment
ENV=development

